      state "ShiftLockFirstPerson" as Jomolith_Play_Player_Camera_State_CameraLogic_CameraState_ShiftLockFirstPerson
    }
    state "ShiftLock" as Jomolith_Play_Player_Camera_State_CameraLogic_CameraState_ShiftLock
  }
  state "Unlocked" as Jomolith_Play_Player_Camera_State_CameraLogic_CameraState_Unlocked
}

Jomolith_Play_Player_Camera_State_CameraLogic_CameraState --> Jomolith_Play_Player_Camera_State_CameraLogic_CameraState : MouseInputOccurred
Jomolith_Play_Player_Camera_State_CameraLogic_CameraState --> Jomolith_Play_Player_Camera_State_CameraLogic_CameraState : PhysicsTick
